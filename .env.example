# ──────────────────────────────────────────────
# RAASOA Configuration
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://raasoa:raasoa_dev@localhost:5433/raasoa

# Object Storage (MinIO/S3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=raasoa
S3_SECRET_KEY=raasoa_dev
S3_BUCKET=raasoa-artifacts

# ──────────────────────────────────────────────
# Embedding Provider: ollama | openai | cohere
# ──────────────────────────────────────────────
EMBEDDING_PROVIDER=ollama

# Embedding vector dimensions (must match model output)
EMBEDDING_DIMENSIONS=768

# ── Ollama (Local, Default) ──────────────────
# Data stays local. No API keys needed.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── OpenAI ───────────────────────────────────
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── Azure OpenAI ─────────────────────────────
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_BASE_URL=https://your-resource.openai.azure.com
# OPENAI_API_VERSION=2024-02-01
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── OpenAI-Compatible (vLLM, LiteLLM, etc.) ─
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=dummy
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_EMBEDDING_MODEL=your-model-name
# EMBEDDING_DIMENSIONS=768

# ── Cohere ───────────────────────────────────
# EMBEDDING_PROVIDER=cohere
# COHERE_API_KEY=xxx
# COHERE_BASE_URL=https://api.cohere.com
# COHERE_EMBEDDING_MODEL=embed-v4.0
# EMBEDDING_DIMENSIONS=1024

# ──────────────────────────────────────────────
# Chunking
# ──────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=80

# Upload limits
MAX_FILE_SIZE_MB=100

# ──────────────────────────────────────────────
# Quality & Governance
# ──────────────────────────────────────────────
QUALITY_GATE_ENABLED=true
QUALITY_PUBLISH_THRESHOLD=0.8

CONFLICT_DETECTION_ENABLED=true
CONFLICT_SEMANTIC_THRESHOLD=0.15

# Claim Extraction (LLM-based, uses Ollama)
CLAIM_EXTRACTION_ENABLED=true
OLLAMA_CHAT_MODEL=qwen3:8b

# Reranking: passthrough | ollama | cohere
RERANKER=passthrough

# ──────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────
AUTH_ENABLED=false

# API Keys: comma-separated "key:tenant_id" pairs
# API_KEYS=sk-dev-key:00000000-0000-0000-0000-000000000001

# Webhook shared secret
# WEBHOOK_SECRET=whsec-your-secret-here

# Dashboard password (empty = open access)
# DASHBOARD_PASSWORD=your-password

# ──────────────────────────────────────────────
# Rate Limiting (requests per minute per tenant)
# ──────────────────────────────────────────────
INGEST_RATE_LIMIT_PER_MINUTE=30
RETRIEVE_RATE_LIMIT_PER_MINUTE=120

# ──────────────────────────────────────────────
# Dashboard
# ──────────────────────────────────────────────
DASHBOARD_ENABLED=true
