# Database
DATABASE_URL=postgresql+asyncpg://raasoa:raasoa_dev@localhost:5433/raasoa

# Object Storage (MinIO/S3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=raasoa
S3_SECRET_KEY=raasoa_dev
S3_BUCKET=raasoa-artifacts

# Embedding Provider: ollama | openai | cohere
EMBEDDING_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cohere (optional)
# COHERE_API_KEY=...
# COHERE_EMBEDDING_MODEL=embed-v4.0

# Embedding dimensions (must match model output)
EMBEDDING_DIMENSIONS=768
